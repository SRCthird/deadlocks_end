		{
			dependencies: ["4BB13C80196FD034"]
			description: ["Andesite Alloy is a material used in Andesite Casing and simple kinetic blocks of Create. Among its many functions, it is an essential ingredient for crafting Shafts and both regular and large Cogwheels. Andesite Alloy is the most basic component construction material in Create."]
			id: "7703F0CA1A8AB6F9"
