				type: "item"
			}]
			title: "&2The Needle in the Trees"
			x: 3.0d
			y: 0.0d
		}
		{
			dependencies: ["23C1A912EB856616"]
			description: [
				"Trust is not free."
				""
				"Give a villager something useful, kind, or valuable. Food. Flowers. Emeralds. Something that says you came as more than a thief."
				""
				"In a world full of teeth, a gift is almost suspicious."
			]
			icon: "minecraft:poppy"
			id: "3DA7060000000001"
			rewards: [{
				id: "3DA7060000000003"
				type: "xp"
				xp: 45
