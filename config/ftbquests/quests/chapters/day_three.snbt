			title: "&7Direction, Memory, Distance"
			x: 1.5d
			y: 0.0d
		}
		{
			dependencies: ["3DA7020000000001"]
			description: [
				"The compass points, but it does not understand what you need."
				""
				"Craft Nature's Compass. Use it to read the shape of the land and choose where your feet should go next."
				""
				"The forest has paths. It simply prefers not to show them."
			]
			icon: "naturescompass:naturescompass"
			id: "3DA7030000000001"
			rewards: [{
				id: "3DA7030000000003"
