			}]
			title: "&bThe Shape of a Settlement"
			x: 7.5d
			y: -1.5d
		}
		{
			dependencies: ["3DA7070000000001"]
			description: [
				"A village is not made from walls."
				""
				"It is made from people who expect those walls to hold."
				""
				"Use the Blueprint to inspect the village. Mark a building, learn who lives nearby, or begin planning what this place needs before the next bad night."
			]
