	quests: [
		{
			dependencies: ["2DA7100000000001"]
			description: [
				"Two mornings have found you alive."
				""
				"The first taught you to cut wood. The second taught you to close wounds."
				""
				"The third asks a worse question: are there still people out there, or only things pretending?"
			]
			icon: "minecraft:sunflower"
			id: "3DA7010000000001"
			rewards: [{
				id: "3DA7010000000003"
				type: "xp_levels"
				xp_levels: 2
			}]
			subtitle: "&8Smoke means fire. Fire means people. Usually."
			tasks: [{
				id: "3DA7010000000002"
				title: "Begin Day Three"
				type: "checkmark"
			}]
			title: "&6The Road to Somewhere"
			x: 0.0d
			y: 0.0d
		}
		{
			dependencies: ["3DA7010000000001"]
			description: [
				"Do not wander blind."
				""
				"The world is too large, too hungry, and too willing to let you walk in circles until night catches up."
				""
				"Make a compass, a map, and a spyglass. Direction, memory, and distance are the first tools of anyone who means to come back."
			]
			icon: "minecraft:compass"
			id: "3DA7020000000001"
			rewards: [{
				id: "3DA7020000000005"
				type: "xp"
				xp: 35
			}]
			subtitle: "&8A road is safer when it has a way back."
