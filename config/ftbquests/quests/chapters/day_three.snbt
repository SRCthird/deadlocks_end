			title: "&dA Small Offering"
			x: 8.5d
			y: 0.0d
		}
		{
			dependencies: ["23C1A912EB856616"]
			description: [
				"Villages keep records because memory rots faster than paper."
				""
				"Craft an MCA Blueprint. Use it to understand the village as more than a cluster of frightened houses."
				""
				"Every settlement has a shape. Every shape has weak points."
			]
			icon: "mca:blueprint"
			id: "3DA7070000000001"
			rewards: [{
				id: "3DA7070000000003"
				type: "xp"
