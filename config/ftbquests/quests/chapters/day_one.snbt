	quests: [
		{
			description: [
				"You wake beneath a sky that does not know your name."
				""
				"An icy chill breahes from the lanters on your left."
				""
				"The trees stand silent. They will not yield to touch."
				""
				"If you want to see sunrise, you will need to learn the old way: stone, fiber, splinters, and flame."
			]
			id: "714048331407D7A8"
			subtitle: "&8The world is listening."
			tasks: [{
				dimension: "minecraft:overworld"
				icon: "minecraft:grass_block"
				id: "78DF3F16CB0647A3"
				title: "Enter the Overworld"
				type: "dimension"
			}]
			title: "&6New Adventure"
			x: 2.0d
			y: -4.5d
		}
		{
			dependencies: ["714048331407D7A8"]
			description: [
				"The forest watches, but it does not help."
				""
				"Break leaves for dead twigs. Strip saplings into sticks. Tear at gravel until the earth gives up flint."
				""
				"Do not waste daylight. It is already bleeding away."
			]
			icon: "minecraft:flint"
			id: "1D1A1D0A4A5E1001"
			rewards: [{
				id: "1D1A1D0A4A5E1004"
